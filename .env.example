JWT_SECRET=change-this-to-a-long-random-secret
BACKUP_SECRET=change-this-to-a-long-random-backup-secret
MYSQL_URL=mysql://user:password@host:3306/database

# Alternative DB variables if MYSQL_URL is not used:
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# Optional Google Drive backup:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_DRIVE_FOLDER_ID=

# Optional SMS:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# FAST2SMS_API_KEY=
# FAST2SMS_ROUTE=q
